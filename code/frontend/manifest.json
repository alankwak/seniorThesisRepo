{
    "manifest_version": 3,
    "name": "CoTab",
    "description": "Easily share your tabs with other users across devices!",
    "version": "0.0.1",
    "action": {
        "default_popup": "popup/popup.html"
    },
    "icons": {
        "16": "icons/icon16.png",
        "19": "icons/icon19.png",
        "32": "icons/icon32.png",
        "38": "icons/icon38.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "background": {
        "service_worker": "background/worker.js",
        "type": "module"
    },
    "side_panel": {
        "default_path": "sidebar/sidebar.html"
    },
    "host_permissions": [
        "http://localhost:3000/*"
    ],
    "permissions": [
        "sidePanel",
        "storage",
        "tabGroups",
        "tabs"
    ]
}